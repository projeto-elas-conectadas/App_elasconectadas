generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  phone      String?
  dob        String?
  occupation String?
  location   String?
  bio        String?
  pfp        String?
  role       UserType

  accountStatus AccountStatus @default(UNVERIFIED)

  produtos     Produto[]
  advertisings AdvertisingOnUsers[]
  posts        PostOnAdmins[]
  otps         OTP[]

  @@map("users")
}

model Produto {
  id        String   @id @default(uuid())
  nome      String
  descricao String
  preco     Float
  categoria String
  imagemUrl String?
  criado_em DateTime @default(now())

  userId  String
  usuario User   @relation(fields: [userId], references: [id])
}

enum AccountStatus {
  VERIFIED
  UNVERIFIED
}

enum UserType {
  USER
  ADMIN
}

model Ads {
  id        String   @id @default(uuid()) // Padronizado para UUID
  title     String
  cover     Bytes?
  createdAt DateTime @default(now())
  content   String
  type      AdType

  users AdvertisingOnUsers[]
}

enum AdType {
  PRODUCT
  SERVICE
  COLLAB
}

model Post {
  id        String   @id @default(uuid()) // Padronizado para UUID
  title     String
  cover     Bytes?
  createdAt DateTime @default(now())
  content   String
  type      PostType

  admins PostOnAdmins[]
}

enum PostType {
  EVENT
  COURSE
}

model AdvertisingOnUsers {
  userId        String
  advertisingId String // Padronizado para String

  user        User @relation(fields: [userId], references: [id])
  advertising Ads  @relation(fields: [advertisingId], references: [id])

  @@id([userId, advertisingId])
}

model PostOnAdmins {
  adminId String
  postId  String // Padronizado para String

  admin User @relation(fields: [adminId], references: [id])
  post  Post @relation(fields: [postId], references: [id])

  @@id([adminId, postId])
}

enum OTPType {
  OTP
  RESET_PASSWORD
}

model OTP {
  id        String   @id @default(uuid()) // Padronizado para UUID
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String
  type      OTPType
  expiresAt DateTime
  createAt  DateTime @default(now())
}
